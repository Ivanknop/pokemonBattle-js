<%- include('header') %>

<% if (finished) { %>
  <section class="winner-banner">
    ¡Ganador: <%= winnerRole %> con <%= winner %>! (Duración: <%= round %> ronda<% if (round !== 1) { %>s<% } %>)
  </section>
<% } %>

<div class="core-screen">
  <section class="battle-container">
    <div class="pokemon-card">
      <h2><%= fighterOne.name %></h2>
      <p>Tipo: <%= fighterOne.type1 %><% if (fighterOne.type2) { %> / <%= fighterOne.type2 %><% } %></p>
      <div class="hp-box">
        <span class="hp-label">HP</span>
        <span class="hp-value"><%= Math.round(fighterOne.hp) %></span>
      </div>
    </div>

    <div class="versus">VS</div>

    <div class="pokemon-card">
      <h2><%= fighterTwo.name %></h2>
      <p>Tipo: <%= fighterTwo.type1 %><% if (fighterTwo.type2) { %> / <%= fighterTwo.type2 %><% } %></p>
      <div class="hp-box">
        <span class="hp-label">HP</span>
        <span class="hp-value"><%= Math.round(fighterTwo.hp) %></span>
      </div>
    </div>
  </section>

  <div class="fight-controls">
    <% if (!finished) { %>
      <div class="luck-bar">
        <span class="luck-current">
          Suerte: <strong><%= playerLuck %></strong> (Jug) / <strong><%= opponentLuck %></strong> (Riv)
        </span>

        <% if (pendingPlayerLuck !== null && pendingPlayerLuck !== undefined) { %>
          <span class="luck-pending">
            Nueva: <strong><%= pendingPlayerLuck %></strong> / <strong><%= pendingOpponentLuck %></strong>
          </span>
          <form action="/fight/luck/accept" method="post" class="luck-form">
            <button type="submit" class="luck-btn accept-luck">Aceptar</button>
          </form>
          <form action="/fight/luck/reject" method="post" class="luck-form">
            <button type="submit" class="luck-btn reject-luck">Rechazar</button>
          </form>
        <% } else if (!luckUsedThisTurn) { %>
          <form action="/fight/luck" method="post" class="luck-form">
            <button type="submit" class="luck-btn roll-luck">Tirar suerte</button>
          </form>
        <% } else { %>
          <span class="luck-used">Suerte usada este turno</span>
        <% } %>
      </div>
    <% } %>

    <% if (finished) { %>
      <div class="winner-actions">
        <span class="winner-text">Vencedor: <%= winner %></span>
        <a href="/choose" class="btn-fight">Nueva batalla</a>
      </div>
    <% } else { %>
      <form action="/fight/next" method="post" class="next-turn-form">
        <button type="submit" class="btn-fight">Nuevo turno</button>
      </form>
    <% } %>
  </div>
</div>

<section class="battle-events">
  <h3>Historial de batalla</h3>
  <% if (events && events.length > 0) { %>
    <ul>
      <% events.forEach(function(event) { %>
        <li><%= event %></li>
      <% }) %>
    </ul>
  <% } else { %>
    <p>La batalla está por comenzar.</p>
  <% } %>
</section>

<%- include('footer') %>
