<%- include('header') %>

<% if (finished) { %>
  <section class="winner-banner">
    Ganador: <%= winner %> Pokémon (<%= winnerRole %>)
  </section>
<% } %>

<h1>Batalla Pokémon</h1>

<section class="battle-container">
  <div class="pokemon-card">
    <h2><%= fighterOne.name %></h2>
    <p>
      Tipo: <%= fighterOne.type1 %><% if (fighterOne.type2) { %> / <%= fighterOne.type2 %><% } %>
    </p>
    <div class="hp-box">
      <span class="hp-label">HP</span>
      <span class="hp-value"><%= Math.round(fighterOne.hp) %></span>
    </div>
  </div>

  <div class="versus">VS</div>

  <div class="pokemon-card">
    <h2><%= fighterTwo.name %></h2>
    <p>
      Tipo: <%= fighterTwo.type1 %><% if (fighterTwo.type2) { %> / <%= fighterTwo.type2 %><% } %>
    </p>
    <div class="hp-box">
      <span class="hp-label">HP</span>
      <span class="hp-value"><%= Math.round(fighterTwo.hp) %></span>
    </div>
  </div>
</section>

<% if (!finished) { %>
  <section class="luck-panel">
    <h3>Suerte del turno</h3>

    <div class="current-luck">
      <div>
        <span class="luck-label">Jugador</span>
        <span class="luck-value"><%= playerLuck %></span>
      </div>
      <div>
        <span class="luck-label">Rival</span>
        <span class="luck-value"><%= opponentLuck %></span>
      </div>
    </div>

    <% if (pendingPlayerLuck !== null && pendingPlayerLuck !== undefined) { %>
      <div class="pending-luck">
        <h4>Nueva tirada</h4>
        <div class="current-luck">
          <div>
            <span class="luck-label">Jugador</span>
            <span class="luck-value"><%= pendingPlayerLuck %></span>
          </div>
          <div>
            <span class="luck-label">Rival</span>
            <span class="luck-value"><%= pendingOpponentLuck %></span>
          </div>
        </div>

        <div class="luck-actions">
          <form action="/fight/luck/accept" method="post">
            <button type="submit" class="luck-button accept-luck">Aceptar nueva suerte</button>
          </form>
          <form action="/fight/luck/reject" method="post">
            <button type="submit" class="luck-button reject-luck">Quedarme con la suerte actual</button>
          </form>
        </div>
      </div>
    <% } else if (!luckUsedThisTurn) { %>
      <form action="/fight/luck" method="post">
        <button type="submit" class="luck-button roll-luck">Tirar suerte</button>
      </form>
    <% } else { %>
      <p class="luck-used-message">Ya usaste la tirada de suerte este turno.</p>
    <% } %>
  </section>
<% } %>

<% if (finished) { %>
  <section class="winner-box">
    <h2>Vencedor: <%= winner %></h2>
    <a href="/choose" class="button-chose-character">Nueva batalla</a>
  </section>
<% } else { %>
  <form action="/fight/next" method="post" class="next-turn-form">
    <button type="submit" class="button-chose-character">Nuevo turno</button>
  </form>
<% } %>

<section class="battle-events">
  <h3>Historial de batalla</h3>
  <% if (events && events.length > 0) { %>
    <ul>
      <% events.forEach(function(event) { %>
        <li><%= event %></li>
      <% }) %>
    </ul>
  <% } else { %>
    <p>La batalla está por comenzar.</p>
  <% } %>
</section>

<%- include('footer') %>
