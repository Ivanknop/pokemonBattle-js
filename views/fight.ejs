<%- include('header') %>
<h1 class="h1">⚔️ COMBATE POKÉMON</h1>
<a href="/choose" class="btn-back">⬅ Volver</a>

<div id="fightArea" style="width:95%; margin:15px auto;">

<!-- Pokemon stats row with HP bar -->
<div style="display:flex; flex-wrap:wrap; gap:20px; justify-content:center;">
  <div style="flex:1; min-width:280px; background:rgba(31,42,68,0.95); border:3px solid #ffcb05; border-radius:12px; padding:15px; box-shadow:0 0 20px rgba(255,203,5,0.2);">
    <h3 style="margin:0 0 10px; text-align:center; color:#2ecc71;" id="playerName"></h3>
    <p style="text-align:center; color:#aaa; font-size:0.85em;" id="playerType"></p>
    <div style="margin-bottom:8px;">
      <div style="display:flex; justify-content:space-between; color:#f0e6d0; font-size:0.9em;">
        <span>❤️ <span id="playerHP"></span></span>
      </div>
      <div style="background:#1a1a2e; border-radius:6px; height:22px; border:1px solid #ffcb05; overflow:hidden;">
        <div id="playerHPBar" style="height:100%; background:linear-gradient(90deg,#2ecc71,#27ae60); border-radius:6px; transition:width 0.5s;"></div>
      </div>
    </div>
    <div style="color:#f0e6d0; font-size:0.8em; display:flex; flex-wrap:wrap; gap:4px 12px; justify-content:center;">
      <span>ATK: <span class="pStat" data-s="attack"></span></span>
      <span>DEF: <span class="pStat" data-s="defense"></span></span>
      <span>SP.ATK: <span class="pStat" data-s="sp_attack"></span></span>
      <span>SP.DEF: <span class="pStat" data-s="sp_defense"></span></span>
      <span>SPD: <span class="pStat" data-s="speed"></span></span>
    </div>
  </div>

  <div style="flex:0 0 auto; display:flex; align-items:center; font-size:2.5em; color:#ffcb05; text-shadow:3px 3px 0 #1a1a2e;">🆚</div>

  <div style="flex:1; min-width:280px; background:rgba(31,42,68,0.95); border:3px solid #ffcb05; border-radius:12px; padding:15px; box-shadow:0 0 20px rgba(255,203,5,0.2);">
    <h3 style="margin:0 0 10px; text-align:center; color:#ef5350;" id="rivalName"></h3>
    <p style="text-align:center; color:#aaa; font-size:0.85em;" id="rivalType"></p>
    <div style="margin-bottom:8px;">
      <div style="display:flex; justify-content:space-between; color:#f0e6d0; font-size:0.9em;">
        <span>❤️ <span id="rivalHP"></span></span>
      </div>
      <div style="background:#1a1a2e; border-radius:6px; height:22px; border:1px solid #ffcb05; overflow:hidden;">
        <div id="rivalHPBar" style="height:100%; background:linear-gradient(90deg,#ef5350,#c0392b); border-radius:6px; transition:width 0.5s;"></div>
      </div>
    </div>
    <div style="color:#f0e6d0; font-size:0.8em; display:flex; flex-wrap:wrap; gap:4px 12px; justify-content:center;">
      <span>ATK: <span class="rStat" data-s="attack"></span></span>
      <span>DEF: <span class="rStat" data-s="defense"></span></span>
      <span>SP.ATK: <span class="rStat" data-s="sp_attack"></span></span>
      <span>SP.DEF: <span class="rStat" data-s="sp_defense"></span></span>
      <span>SPD: <span class="rStat" data-s="speed"></span></span>
    </div>
  </div>
</div>

<!-- Type effectiveness indicator -->
<div id="typeEffectiveness" style="text-align:center; margin:10px 0; font-size:1.1em; min-height:1.5em;"></div>

<!-- Battle Log -->
<div id="battleLog" style="margin-top:20px; background:rgba(31,42,68,0.95); border:3px solid #ffcb05; border-radius:12px; padding:15px; box-shadow:0 0 20px rgba(255,203,5,0.2); max-height:350px; overflow-y:auto;">
  <h2 style="color:#ffcb05; font-size:1.5em; text-align:center; margin:0 0 10px;">🗣️ Bitácora de Batalla</h2>
  <div id="logEntries"></div>
</div>

<!-- Controls -->
<div style="display:flex; flex-wrap:wrap; gap:12px; justify-content:center; margin-top:15px;">
  <button id="nextRoundBtn" class="button-chose-character" style="font-size:1.5em;">🎲 SIGUIENTE ROUND</button>
</div>

<!-- Chart -->
<canvas id="fightChart" width="400" height="200" style="display:none;"></canvas>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
(function() {
  var pData = <%- playerData %>;
  var rData = <%- rivalData %>;

  var player = JSON.parse(JSON.stringify(pData));
  var rival = JSON.parse(JSON.stringify(rData));

  player.currentHP = player.hp;
  rival.currentHP = rival.hp;

  var round = 0;
  var fightOver = false;

  var $ = function(id) { return document.getElementById(id); };
  var logEl = $('logEntries');

  var TYPE_CHART = {
    normal: { rock: 0.5, ghost: 0, steel: 0.5 },
    fire: { fire: 0.5, water: 0.5, grass: 2, ice: 2, bug: 2, rock: 0.5, dragon: 0.5, steel: 2 },
    water: { fire: 2, water: 0.5, grass: 0.5, ground: 2, rock: 2, dragon: 0.5 },
    electric: { water: 2, electric: 0.5, grass: 0.5, ground: 0, flying: 2, dragon: 0.5 },
    grass: { fire: 0.5, water: 2, grass: 0.5, poison: 0.5, ground: 2, flying: 0.5, bug: 0.5, rock: 2, dragon: 0.5, steel: 0.5 },
    ice: { fire: 0.5, water: 0.5, grass: 2, ice: 0.5, ground: 2, flying: 2, dragon: 2, steel: 0.5 },
    fighting: { normal: 2, ice: 2, poison: 0.5, flying: 0.5, psychic: 0.5, bug: 0.5, rock: 2, ghost: 0, dark: 2, steel: 2, fairy: 0.5 },
    poison: { grass: 2, poison: 0.5, ground: 0.5, rock: 0.5, ghost: 0.5, steel: 0, fairy: 2 },
    ground: { fire: 2, electric: 2, grass: 0.5, poison: 2, flying: 0, bug: 0.5, rock: 2, steel: 2 },
    flying: { electric: 0.5, grass: 2, fighting: 2, bug: 2, rock: 0.5, steel: 0.5 },
    psychic: { fighting: 2, poison: 2, psychic: 0.5, dark: 0, steel: 0.5 },
    bug: { fire: 0.5, grass: 2, fighting: 0.5, poison: 0.5, flying: 0.5, psychic: 2, ghost: 0.5, dark: 2, steel: 0.5, fairy: 0.5 },
    rock: { fire: 2, ice: 2, fighting: 0.5, ground: 0.5, flying: 2, bug: 2, steel: 0.5 },
    ghost: { normal: 0, psychic: 2, ghost: 2, dark: 0.5 },
    dragon: { dragon: 2, steel: 0.5, fairy: 0 },
    dark: { fighting: 0.5, psychic: 2, ghost: 2, dark: 0.5, fairy: 0.5 },
    steel: { fire: 0.5, water: 0.5, electric: 0.5, ice: 2, rock: 2, steel: 0.5, fairy: 2 },
    fairy: { fire: 0.5, fighting: 2, poison: 0.5, dragon: 2, dark: 2, steel: 0.5 },
  };

  function typeMult(attackType, defType1, defType2) {
    var m = TYPE_CHART[attackType.toLowerCase()]?.[defType1.toLowerCase()] ?? 1;
    if (defType2 && defType2 !== '') {
      m *= TYPE_CHART[attackType.toLowerCase()]?.[defType2.toLowerCase()] ?? 1;
    }
    return m;
  }

  function renderStats() {
    $('playerName').textContent = '\u{1F431} ' + player.name;
    $('rivalName').textContent = '\u{1F409} ' + rival.name;
    $('playerType').textContent = player.type1 + (player.type2 ? ' / ' + player.type2 : '');
    $('rivalType').textContent = rival.type1 + (rival.type2 ? ' / ' + rival.type2 : '');
    $('playerHP').textContent = Math.max(0, Math.round(player.currentHP)) + ' / ' + player.hp;
    $('rivalHP').textContent = Math.max(0, Math.round(rival.currentHP)) + ' / ' + rival.hp;

    var hpPct = Math.max(0, player.currentHP / player.hp * 100);
    $('playerHPBar').style.width = hpPct + '%';
    hpPct = Math.max(0, rival.currentHP / rival.hp * 100);
    $('rivalHPBar').style.width = hpPct + '%';

    document.querySelectorAll('.pStat').forEach(function(el) {
      el.textContent = player[el.dataset.s];
    });
    document.querySelectorAll('.rStat').forEach(function(el) {
      el.textContent = rival[el.dataset.s];
    });

    // Type effectiveness
    var pMult = typeMult(player.type1, rival.type1, rival.type2);
    var rMult = typeMult(rival.type1, player.type1, player.type2);
    var te = $('typeEffectiveness');
    var text = '';
    if (pMult > 1) text += '✅ Tu ataque es súper efectivo';
    else if (pMult === 0) text += '❌ Tu ataque no tiene efecto';
    else if (pMult < 1) text += '⚠️ Tu ataque es poco efectivo';
    text += ' | ';
    if (rMult > 1) text += '🔴 El rival es súper efectivo';
    else if (rMult === 0) text += '🟢 El rival no tiene efecto';
    else if (rMult < 1) text += '🟡 El rival es poco efectivo';
    te.textContent = text;
  }

  function addLog(text, css) {
    var p = document.createElement('p');
    p.className = 'fight ' + (css || '');
    p.textContent = text;
    logEl.appendChild(p);
    $('battleLog').scrollTop = $('battleLog').scrollHeight;
  }

  function resolveAttack(att, def) {
    var atkType = att.type1;
    var mult = typeMult(atkType, def.type1, def.type2);

    if (mult === 0) {
      return { text: att.name + ' atacó pero no tuvo efecto contra ' + def.name, css: 'block' };
    }

    // Dodge
    var dodgeChance = Math.max(0, (def.speed - att.speed) / 500);
    if (Math.random() < dodgeChance) {
      return { text: '🍀 ¡' + def.name + ' esquiva el ataque!', css: 'block' };
    }

    // Hit roll
    var atkRoll = att.speed * 0.3 + att.attack * 0.4 + Math.random() * 30;
    var defRoll = def.speed * 0.4 + def.defense * 0.3 + Math.random() * 30;
    if (atkRoll < defRoll) {
      return { text: att.name + ' erró el ataque', css: 'block' };
    }

    // Damage
    var offensive = att.attack * 0.6 + att.sp_attack * 0.4;
    var defensive = def.defense * 0.5 + def.sp_defense * 0.3;
    var damage = Math.max(1, Math.round((offensive - defensive) * mult));

    // Block
    if (def.speed >= att.speed * 1.5 && Math.random() < 0.3) {
      damage = Math.max(1, Math.round(damage * 0.25));
      def.currentHP -= damage;
      return { text: def.name + ' bloqueó parcialmente, recibiendo solo ' + damage + ' de daño', css: 'hit' };
    }

    // Crit
    var critChance = 0.05 + (att.speed - def.speed) / 1000;
    if (Math.random() < Math.max(0.01, critChance)) {
      damage = Math.round(damage * 2);
      def.currentHP -= damage;
      return { text: '💥 ¡' + att.name + ' da un GOLPE CRÍTICO de ' + damage + ' a ' + def.name + '!', css: 'hit' };
    }

    var effText = mult > 1 ? ' (¡súper efectivo!)' : mult < 1 ? ' (poco efectivo...)' : '';
    def.currentHP -= damage;
    return { text: att.name + ' ataca por ' + damage + ' a ' + def.name + effText, css: 'hit' };
  }

  function nextRound() {
    if (fightOver) return;
    round++;

    var e1 = resolveAttack(player, rival);
    addLog(e1.text, e1.css);

    if (rival.currentHP > 0) {
      var e2 = resolveAttack(rival, player);
      addLog(e2.text, e2.css);
    }

    renderStats();

    if (player.currentHP <= 0 || rival.currentHP <= 0) {
      fightOver = true;
      var winner = player.currentHP > 0 ? player : rival;
      addLog('\u{1F3C6} ¡La batalla ha terminado! ¡Vencedor: ' + winner.name + '!', 'winner');
      $('nextRoundBtn').disabled = true;
      $('nextRoundBtn').textContent = '\u{1F3C6} COMBATE FINALIZADO';
      drawChart();
    }
  }

  function drawChart() {
    var c = document.getElementById('fightChart');
    c.style.display = 'block';
    c.style.margin = '20px auto';
    c.style.maxWidth = '500px';
    var ctx = c.getContext('2d');

    var labels = ['HP','Attack','Defense','Sp.Atk','Sp.Def','Speed'];
    var pVals = [player.hp, player.attack, player.defense, player.sp_attack, player.sp_defense, player.speed];
    var rVals = [rival.hp, rival.attack, rival.defense, rival.sp_attack, rival.sp_defense, rival.speed];

    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [
          { label: '\u{1F431} ' + player.name, data: pVals,
            backgroundColor: 'rgba(46,204,113,0.8)', borderColor: 'rgba(46,204,113,1)', borderWidth: 2 },
          { label: '\u{1F409} ' + rival.name, data: rVals,
            backgroundColor: 'rgba(239,83,80,0.8)', borderColor: 'rgba(239,83,80,1)', borderWidth: 2 },
        ],
      },
      options: {
        responsive: true,
        plugins: {
          title: { display: true, text: '\u{1F3C6} Comparación Final', color: '#ffcb05', font: { size: 16 } },
          legend: { labels: { color: '#f0e6d0', font: { size: 12 } } },
        },
        scales: {
          y: { beginAtZero: true, ticks: { color: '#f0e6d0' }, grid: { color: 'rgba(255,203,5,0.15)' } },
          x: { ticks: { color: '#f0e6d0' }, grid: { color: 'rgba(255,203,5,0.1)' } },
        },
      },
    });
  }

  $('nextRoundBtn').addEventListener('click', nextRound);

  renderStats();
  addLog('\u{2694}\uFE0F ¡Comienza el combate entre ' + player.name + ' y ' + rival.name + '!', 'winner');
})();
</script>

<%- include('footer') %>
